# macOS code signing identity in your login keychain
CSC_NAME="Developer ID Application: Your Name (TEAMID)"

# Apple notarization API key auth (App Store Connect)
# Use an absolute path to the AuthKey_XXXXXX.p8 file on your Mac
APPLE_API_KEY="/absolute/path/to/AuthKey_XXXXXXXXXX.p8"
APPLE_API_KEY_ID="XXXXXXXXXX"
APPLE_API_ISSUER="00000000-0000-0000-0000-000000000000"
